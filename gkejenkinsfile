pipeline {
  agent any

  environment {
    PROJECT_ID = "project-1455a657-6267-4254-95c"
    REGION     = "us-central1"
    REPO       = "java-repo"
    IMAGE_NAME = "demo-app"
    IMAGE = "us-central1-docker.pkg.dev/$PROJECT_ID/$REPO/demo-app"
    CLUSTER    = "nitwallah"
    ZONE       = "us-central1-c"
  }

  stages {

    // stage('Checkout Code') {
    //   steps {
    //     git 'https://github.com/your-org/java-gke-app.git'
    //   }
    // }

    stage('Maven Build') {
      steps {
        sh 'mvn clean package'
      }
    }

    stage('Build Image') {
      steps {
        sh """
        docker build -t $IMAGE:$BUILD_NUMBER .
        docker push $IMAGE:$BUILD_NUMBER
        """
      }
    }

    stage('Deploy to GKE') {
      steps {
        sh """
        gcloud container clusters get-credentials $CLUSTER --zone $ZONE
        kubectl get deployment demo-app || kubectl apply -f kubernetes/Deployment.yaml
        kubectl set image deployment/demo-app \
         demo=$IMAGE:$BUILD_NUMBER
        """
      }
    }
  }

  post {
    success {
      echo "✅ Application deployed successfully to GKE"
    }
    failure {
      echo "❌ Deployment failed"
    }
  }
}
